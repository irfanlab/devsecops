<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        CVE-2016-1000027 - Spring Framework HttpInvokerServiceExporter
        This is a well-known false positive. The CVE relates to HttpInvokerServiceExporter
        which uses Java serialization for remote invocations. This class is deprecated and
        not used in this project. Spring Framework team has acknowledged this as a false positive.
        See: https://github.com/spring-projects/spring-framework/issues/24434
    -->
    <suppress>
        <notes><![CDATA[
            CVE-2016-1000027 is a false positive. HttpInvokerServiceExporter is deprecated and not used.
        ]]></notes>
        <cve>CVE-2016-1000027</cve>
    </suppress>

</suppressions>
